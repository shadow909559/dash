{
  "name": "@dash/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types and constants for DASH",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest 2>/dev/null || echo 'No JS tests yet'"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
