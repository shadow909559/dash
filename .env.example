# DASH Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Application
DASH_APP_NAME=DASH
DASH_ENV=development
DASH_DEBUG=true
DASH_LOG_LEVEL=INFO

# Backend API
DASH_HOST=0.0.0.0
DASH_PORT=8000
DASH_API_PREFIX=/api/v1
DASH_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (scaffold only — not used in foundation milestone)
DASH_DATABASE_URL=postgresql+asyncpg://dash:dash@localhost:5432/dash

# Redis (scaffold only — not used in foundation milestone)
DASH_REDIS_URL=redis://localhost:6379/0

# AI Providers (scaffold only — not used in foundation milestone)
DASH_OPENAI_API_KEY=
DASH_OPENAI_BASE_URL=https://api.openai.com/v1
DASH_OLLAMA_BASE_URL=http://localhost:11434

# Desktop
DASH_BACKEND_URL=http://localhost:8000
