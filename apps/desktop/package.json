  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
