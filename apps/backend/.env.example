# Copy this file to .env and adjust values for your environment.
# No secrets are committed to source control; this file only
# documents variable names and safe local defaults.

# --- General ---------------------------------------------------------
APP_NAME=DASH Backend
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Server ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Logging -----------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false

# --- CORS ----------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# --- Database (connection plumbing only, no models yet) -----------------
DATABASE_URL=postgresql+psycopg://dash:dash@localhost:5432/dash
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# --- Redis (connection info only, not wired up yet) ----------------------
REDIS_URL=redis://localhost:6379/0
